# Postgres connection string used by the app and drizzle-kit.
DATABASE_URL=postgresql://artefacts:artefacts@localhost:5432/artefacts

# Auth.js secret. Generate one with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=replace-me

# Anthropic API key for the Claude Agent SDK (used from Phase 1 onward).
ANTHROPIC_API_KEY=sk-ant-...

# Public URL of the builder, used to build links in emails (Auth.js also uses
# AUTH_URL). Falls back to http://localhost:3000 if unset.
AUTH_URL=http://localhost:3000

# --- Outgoing mail (SMTP, e.g. IONOS) -------------------------------------
# Used for the "welcome" email on signup and password-reset links.
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587                          # 587 = STARTTLS (recommended); 465 = SSL
SMTP_SECURE=false                      # true only for port 465
SMTP_USER=noreply@kubikraum.digital    # full mailbox address
SMTP_PASS=replace-me
MAIL_FROM="artefacts <noreply@kubikraum.digital>"  # sender; defaults to SMTP_USER

# Password-reset link lifetime in hours.
MAIL_RESET_TTL_HOURS=1

# Optional: override the email copy without a rebuild. Defaults live in
# lib/mail-templates.ts. Templates use {{name}}, {{appUrl}}, {{resetUrl}},
# {{expiresHours}} tokens. Put the full HTML on a single line.
# MAIL_WELCOME_SUBJECT=Willkommen bei artefacts 🎉
# MAIL_WELCOME_HTML=<!doctype html>...
# MAIL_RESET_SUBJECT=Passwort zurücksetzen
# MAIL_RESET_HTML=<!doctype html>...
