# Compose / Coolify environment. Copy to .env for local `docker compose up`,
# or set these in the Coolify UI.
POSTGRES_USER=artefacts
POSTGRES_PASSWORD=change-me
POSTGRES_DB=artefacts

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# --- cortecs.ai LLM router -------------------------------------------------
# All LLM traffic routes through cortecs.ai (Europe's AI gateway, EUR billing).
# The website builder uses the Anthropic-compatible endpoint via the Agent SDK;
# cleanup tasks + the future "Sovereign Servers" option use the OpenAI-compatible
# endpoint (which also passes eu_native / preference routing).
CORTECS_API_KEY=ctx-...
# Base URLs (defaults shown — override only for self-hosted/proxy setups).
CORTECS_ANTHROPIC_BASE_URL=https://api.cortecs.ai
CORTECS_OPENAI_BASE_URL=https://api.cortecs.ai/v1
# Model per task. Builder = a Claude model (Anthropic path); cleanup = any cheap
# model (OpenAI path); interview = generates the first-prompt concept questions
# (OpenAI path, fast); sovereign = EU-native builder model (used later).
# IMPORTANT: use cortecs.ai's OWN catalog id, which differs from Anthropic's
# canonical id. Opus 4.8 on cortecs is "claude-opus4-8" (no hyphen after "opus"),
# NOT "claude-opus-4-8". Verify names at GET https://api.cortecs.ai/v1/models.
CORTECS_BUILD_MODEL=claude-opus4-8
CORTECS_CLEANUP_MODEL=claude-haiku-4-5
CORTECS_INTERVIEW_MODEL=claude-4-6-sonnet
CORTECS_SOVEREIGN_BUILD_MODEL=claude-opus4-8
# --- Billing / credits -----------------------------------------------------
# Customer markup on raw Cortecs cost (1.20 = +20% margin), one-time free credit
# in EUR granted on first use, model-price cache TTL (ms), and a safety
# multiplier if the /v1/models catalog is NET of Cortecs' 5% fee (then 1.05).
BILLING_MARGIN=1.20
FREE_TIER_GRANT_EUR=2.00
CORTECS_PRICE_TTL_MS=3600000
CORTECS_FEE_MULTIPLIER=1.0

# Referral coupons: credit for the redeemer, bonus for the referrer, and the
# window (days) the invitee has to subscribe for the referrer bonus to qualify.
# Also editable in the admin /settings; blank falls back to these code defaults.
REFERRAL_RECIPIENT_EUR=10.00
REFERRAL_REFERRER_EUR=5.00
REFERRAL_WINDOW_DAYS=14

# --- Stock photos (Pexels) ---------------------------------------------------
# Free API key from https://www.pexels.com/api/ (200 req/h, 20k/month). Lets the
# builder agent search real stock photos (with visible previews) and save them
# into a project's file tree as local assets. Optional — without a key the
# photo tools are disabled and the agent uses SVG/CSS imagery instead.
PEXELS_API_KEY=

# --- Backups ----------------------------------------------------------------
# Daily full-app backups (files + per-project DB + end-user accounts + attach-
# ments + settings) of PUBLISHED projects, via POST /api/cron/backup — triggered
# once a day by an external scheduler (e.g. a Coolify Scheduled Task) sending
# this bearer secret. Generate: openssl rand -base64 32. Unset → route closed.
# RETENTION_DAYS / ENABLED are also editable in admin /settings (blank → code
# defaults: 7 days / on).
BACKUP_CRON_SECRET=
BACKUP_ENABLED=
BACKUP_RETENTION_DAYS=

# --- OpenGraph thumbnails (screenshot service) ------------------------------
# Whenever a project's /index.html changes, web renders a 1200x630 preview of the
# page header via the internal `shot` container and links it as og:image. The URL
# defaults to the compose service (http://shot:3000); leave blank to DISABLE the
# feature entirely. SECRET is a shared secret between web and shot (env-only, like
# AUTH_SECRET) — generate with: openssl rand -base64 32. Unset on shot → it
# refuses every request. THUMBNAIL_ENABLED is a kill-switch (also editable in
# admin /settings; blank → on).
SCREENSHOT_SERVICE_URL=http://shot:3000
SCREENSHOT_SERVICE_SECRET=
THUMBNAIL_ENABLED=

# --- Stripe billing (Payment Links) ----------------------------------------
# Two static Payment Links (create in the Stripe dashboard): a 5€/month per-app
# hosting subscription + one-time top-ups (5/10/20€). The webhook (POST
# /api/stripe/webhook) grants credit / flips hosting on payment.
# SECRET_KEY (restricted key) + WEBHOOK_SECRET (endpoint signing secret) are
# secrets — env-only, unset → the webhook route rejects. Generate the webhook
# secret in the dashboard when you add the endpoint.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Payment Link base URLs (non-secret; also editable in admin /settings). Blank →
# the corresponding button is hidden. We append ?client_reference_id=…&
# prefilled_email=… at click time for attribution.
STRIPE_SUBSCRIPTION_LINK=
STRIPE_TOPUP_LINK_5=
STRIPE_TOPUP_LINK_10=
STRIPE_TOPUP_LINK_20=
# EUR builder credit included per paid subscription invoice (expires monthly).
SUBSCRIPTION_MONTHLY_CREDIT_EUR=5.00

# --- Transactional email (SMTP, e.g. IONOS) --------------------------------
# Used for the welcome + password-reset mails. SMTP_PASS is a secret and stays
# here; the rest (host/port/user/secure/from) can also be edited in the admin
# panel without a redeploy — see the settings note below.
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=mail@example.com
SMTP_PASS=change-me
# true for port 465 (implicit TLS), false/blank for 587 (STARTTLS).
SMTP_SECURE=false
MAIL_FROM=Kubikraum <mail@example.com>

# NOTE: the non-secret Cortecs / Billing / SMTP values above are also editable
# in the admin panel (stored in the `app_setting` table). A saved admin value
# OVERRIDES the env var here (precedence: DB > env > code default), so the model,
# margin, etc. can be changed live without a redeploy. Secrets (CORTECS_API_KEY,
# SMTP_PASS) are env-only and NOT surfaced in the admin panel.

# Wildcard sub-zone where generated apps are served (Way 3). The builder runs on
# the main domain; each project's preview/publish is served from
# <label>.apps.<this value>, e.g. preview-<projectId>.apps.example.com.
# Requires a wildcard DNS record (*.apps.<domain>) + wildcard TLS in Coolify.
# For local dev you can use: APPS_DOMAIN=apps.localhost
APPS_DOMAIN=apps.example.com

# Public URL of the builder, baked into the separate landing app (kubikraum.digital)
# so its prompt box can hand off to the builder's /start route.
NEXT_PUBLIC_BUILDER_URL=https://app.kubikraum.digital

# --- Admin panel (separate read-only app, e.g. admin.kubikraum.digital) -----
# Single login checked against this pair; the session cookie is HMAC-signed with
# ADMIN_SECRET (use a long random string, e.g. openssl rand -base64 32).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
ADMIN_SECRET=replace-me

# Lets the admin panel publish / take a user's app offline. The admin calls web's
# internal /api/admin/projects endpoint with this shared bearer, so it must be set
# to the SAME value on BOTH the web and admin services. Env-only (never in the
# app_setting table); unset → the endpoint is closed and the buttons error out.
# Use a long random string, e.g. openssl rand -base64 32.
ADMIN_API_SECRET=replace-me
# web's address on the internal compose network (admin → web). Default is fine for
# the standard stack; override only for a non-standard deployment / local dev.
WEB_INTERNAL_URL=http://web:3000

# External MCP editing bridge (POST /api/mcp). Lets a support operator point their
# OWN AI (e.g. Claude Code) at one user's app to help build it WITHOUT spending the
# user's credit and WITHOUT writing to the user's chat. This shared bearer is the
# only gate — env-only (never in the app_setting table); unset → the endpoint is
# closed (401). Use a long random string, e.g. openssl rand -base64 32. Connect with:
#   claude mcp add --transport http artefacts-app \
#     "https://<builder-host>/api/mcp?app=<PROJECT_ID>" \
#     --header "Authorization: Bearer $DEV_API_SECRET"
DEV_API_SECRET=
