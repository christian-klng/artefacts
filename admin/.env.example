# Read-only admin panel for artefacts. Shares the builder's Postgres.

# Same database the builder/migrate services use.
DATABASE_URL=postgresql://artefacts:artefacts@localhost:5432/artefacts

# Single admin login (checked against these two values, constant-time).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Secret used to HMAC-sign the admin session cookie. Use a long random string.
ADMIN_SECRET=replace-me
